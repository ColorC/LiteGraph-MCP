# IGame Graph RAG 环境变量配置
# 复制此文件为 .env 并根据实际情况修改

# =============================================================================
# 运行模式配置
# =============================================================================

# 运行模式：standalone (stdio + HTTP + Web) | stdio (仅 stdio MCP) | http (仅 HTTP + Web)
IGAME_MODE=standalone

# 服务绑定地址
IGAME_HOST=0.0.0.0

# Web UI 端口
IGAME_WEB_PORT=8000

# MCP HTTP 端口
IGAME_MCP_PORT=8001

# 日志级别：DEBUG | INFO | WARNING | ERROR
IGAME_LOG_LEVEL=INFO

# =============================================================================
# 数据存储配置
# =============================================================================

# 数据目录路径（SQLite 数据库存储位置）
IGAME_DATA_DIR=./data

# =============================================================================
# LLM 配置（智谱 AI）
# =============================================================================

# LLM API Key
LLM_API_KEY=your_api_key_here

# 或使用 GLM 专用变量名
GLM_API_KEY=your_api_key_here

# LLM API 端点 URL
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# LLM 模型名称
LLM_MODEL=glm-4

# =============================================================================
# Embedding 配置（可选，如使用本地嵌入）
# =============================================================================

# Embedding 模型路径或 API
EMBEDDING_MODEL=bge-m3
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=

# =============================================================================
# Wiki集成配置（可选）
# =============================================================================

WIKI_APP_ID=
WIKI_APP_SECRET=

# =============================================================================
# Windows 文件桥接配置（Index-Only / RepoMap 远程读文件）
# =============================================================================

# 桥接服务地址（建议指向 IGameAgentClient；index_only 不允许本地回退）
WINDOWS_FILE_BRIDGE_URL=http://localhost:8765

# 是否启用自动拉起与自愈（1=启用，0=关闭）
WINDOWS_FILE_BRIDGE_AUTOSTART=1

# 桥接启动命令（留空则自动使用本仓库 scripts/start_file_bridge.sh）
# 注意：开发阶段不做 fallback，必须确保 IGameAgentClient 提供 /read_file。
WINDOWS_FILE_BRIDGE_START_CMD=

# 健康检查周期（秒）
WINDOWS_FILE_BRIDGE_HEALTH_INTERVAL_SEC=8

# 健康检查超时（秒）
WINDOWS_FILE_BRIDGE_HEALTH_TIMEOUT_SEC=2
